# ── 服务端口 ──
API_GATEWAY_PORT=3000
USER_SERVICE_PORT=3001
PRODUCT_SERVICE_PORT=3002
CART_SERVICE_PORT=3003
ORDER_SERVICE_PORT=3004

# ── PostgreSQL ──
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/ecommerce
# DATABASE_READ_URL=postgresql://postgres:postgres@localhost:5433/ecommerce  # 从库（不设则自动退化为 DATABASE_URL）
POSTGRES_PASSWORD=postgres

# ── Redis ──
REDIS_URL=redis://localhost:6379

# ── JWT ──
JWT_ACCESS_SECRET=your-access-secret-change-in-production
JWT_REFRESH_SECRET=your-refresh-secret-change-in-production
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# ── 服务间通信 ──
INTERNAL_SECRET=your-internal-secret-change-in-production

# ── 环境 ──
NODE_ENV=development
LOG_LEVEL=debug

# ── CORS ──
CORS_ORIGINS=http://localhost:3000,http://localhost:5173

# ── 下游服务 URL（Docker 环境由 compose 自动设置，本地开发留空使用默认值） ──
# USER_SERVICE_URL=http://user-service:3001
# PRODUCT_SERVICE_URL=http://product-service:3002
# CART_SERVICE_URL=http://cart-service:3003
# ORDER_SERVICE_URL=http://order-service:3004
