# Production: replace :80 with your domain, e.g. shop.example.com
:80 {
	reverse_proxy app:3000

	encode gzip zstd

	header {
		X-Content-Type-Options nosniff
		X-Frame-Options DENY
		Referrer-Policy strict-origin-when-cross-origin
		-Server
	}

	log {
		output stdout
		format json
	}
}
