{
  "name": "hono-api",
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev": "bun run --hot src/index.ts",
    "start": "bun run src/index.ts",
    "d:up": "docker compose -f docker-compose.dev.yml up -d",
    "d:redis": "docker compose -f docker-compose.dev.yml up -d redis",
    "d:down": "docker compose -f docker-compose.dev.yml down",
    "format": "prettier --write \"src/**/*.ts\""
  },
  "dependencies": {
    "@hono/zod-validator": "^0.7.6",
    "@types/bcrypt": "^6.0.0",
    "@types/pg": "^8.16.0",
    "bcrypt": "^6.0.0",
    "dotenv": "^17.3.1",
    "drizzle-kit": "^0.31.9",
    "drizzle-orm": "^0.45.1",
    "hono": "^4.0.0",
    "postgres": "^3.4.8",
    "redis": "^5.11.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "prettier": "^3.8.1"
  },
  "peerDependencies": {
    "typescript": "^5"
  }
}