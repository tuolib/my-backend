{
  "name": "ho-ecommerce",
  "version": "1.0.0",
  "type": "module",
  "workspaces": [
    "apps/*",
    "services/*",
    "packages/*"
  ],
  "scripts": {
    "dev:gateway": "bun run --filter api-gateway dev",
    "dev:order": "bun run --filter order-service dev",
    "dev:up": "bun run dev:gateway",
    "dev": "bun run dev:gateway",
    "docker:dev": "docker compose -f infra/local-dev/docker-compose.yml up -d redis db",
    "docker:dev:down": "docker compose -f infra/local-dev/docker-compose.yml down",
    "docker:prod": "docker compose up --build -d",
    "docker:prod:down": "docker compose down",
    "docker:prod:logs": "docker compose logs -f",
    "lint": "prettier check packages/",
    "format": "prettier format --write packages/"
  },
  "dependencies": {
    "drizzle-orm": "^0.38.0",
    "hono": "^4.7.0",
    "ioredis": "^5.4.2",
    "pg": "^8.19.0",
    "pino": "^9.6.0",
    "postgres": "^3.4.5",
    "prettier": "^3.8.1",
    "zod": "^3.24.0"
  },
  "devDependencies": {
    "@types/bun": "^1.2.0",
    "@types/ioredis": "^5.0.0",
    "drizzle-kit": "^0.30.0",
    "typescript": "^5.7.0"
  }
}
