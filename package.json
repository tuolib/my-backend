{
  "name": "hono-api",
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "d:up": "docker compose -f docker-compose.dev.yml up -d",
    "format": "node_modules/.bin/prettier --write \"src/**/*.ts\"",
    "dr": "docker compose -f docker-compose.dev.yml up -d redis db",
    "dev": "bun run dr && bun run dev:hot",
    "dev:hot": "bun run --hot src/index.ts",
    "stop": "docker compose -f docker-compose.dev.yml stop",
    "down": "docker compose -f docker-compose.dev.yml down",
    "swarm:init": "bash scripts/swarm/init-manager.sh",
    "swarm:label": "bash scripts/swarm/label-nodes.sh",
    "swarm:deploy": "bash scripts/swarm/deploy-stack.sh",
    "swarm:down": "bash scripts/swarm/remove-stack.sh",
    "db:generate": "bun drizzle-kit generate",
    "db:migrate": "bun run src/index.ts --migrate-only",
    "migrate": "bun run src/db/migrate.ts",
    "migrate:down": "bun run src/db/migrate.ts --down",
    "sim:up": "docker compose -f docker-compose.sim.yml up --build -d",
    "sim:migrate": "docker compose -f docker-compose.sim.yml run --rm api-1 bun run migrate",
    "sim:migrate:run": "docker compose -f docker-compose.sim.yml run --rm api-1 bun run migrate",
    "sim:migrate:exec": "docker compose -f docker-compose.sim.yml exec api-1 bun run migrate",
    "sim:logs:api-1": "docker compose -f docker-compose.sim.yml logs -f api-1",
    "sim:logs:api-2": "docker compose -f docker-compose.sim.yml logs -f api-2",
    "sim:logs:postgres-primary": "docker compose -f docker-compose.sim.yml logs -f postgres-primary",
    "sim:logs:pgbouncer-rw": "docker compose -f docker-compose.sim.yml logs -f pgbouncer-rw",
    "sim:logs:tail": "docker compose -f docker-compose.sim.yml logs --tail=200 api-1 postgres-primary",
    "sim:down": "docker compose -f docker-compose.sim.yml down",
    "sim:clean": "docker compose -f docker-compose.sim.yml down -v",
    "log:up": "docker compose -f docker-compose.logging.yml up -d",
    "log:down": "docker compose -f docker-compose.logging.yml down",
    "log:tail": "docker compose -f docker-compose.logging.yml logs -f --tail=200 promtail loki grafana"
  },
  "dependencies": {
    "@hono/zod-validator": "^0.7.6",
    "@types/bcrypt": "^6.0.0",
    "@types/pg": "^8.16.0",
    "bcrypt": "^6.0.0",
    "dotenv": "^17.3.1",
    "drizzle-kit": "^0.31.9",
    "drizzle-orm": "^0.45.1",
    "hono": "^4.0.0",
    "postgres": "^3.4.8",
    "redis": "^5.11.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "prettier": "^3.8.1"
  },
  "peerDependencies": {
    "typescript": "^5"
  }
}
