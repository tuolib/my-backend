{
  "name": "@repo/database",
  "version": "0.1.0",
  "type": "module",
  "exports": {
    ".": "./src/index.ts",
    "./client": "./src/client.ts",
    "./schema": "./src/schema/index.ts"
  },
  "scripts": {
    "generate": "drizzle-kit generate",
    "migrate": "bun run --env-file ../../.env src/migrate.ts",
    "seed": "bun run --env-file ../../.env src/seed.ts",
    "seed:prod": "bun run --env-file ../../.env src/seed-prod.ts",
    "seed:prod:reset": "bun run --env-file ../../.env src/seed-prod.ts --reset-seed",
    "data:migrate": "bun run --env-file ../../.env src/data-migrate.ts",
    "studio": "drizzle-kit studio"
  },
  "dependencies": {
    "@repo/shared": "workspace:*",
    "drizzle-orm": "^0.38.0",
    "ioredis": "^5.4.2",
    "postgres": "^3.4.5"
  },
  "devDependencies": {
    "drizzle-kit": "^0.30.0"
  }
}
