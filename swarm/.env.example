# Stack
STACK_NAME=ho
SWARM_DOMAIN=api.finde345.site
DEPLOY_MODE=auto

# Image
IMAGE_REPOSITORY=ghcr.io/your-org/ho-api
IMAGE_TAG=latest

# API
API_REPLICAS=
API_REPLICAS_SINGLE=2
API_REPLICAS_MULTI=10
DB_POOL_MAX=5
DB_STRICT_READ_READINESS=false
LOG_LEVEL=info

# Database
POSTGRES_DB=mydb
POSTGRES_USER=user
POSTGRES_PASSWORD=password
POSTGRES_REPLICATION_PASSWORD=repl_password

# PgBouncer
PGBOUNCER_MAX_CLIENT_CONN=5000
PGBOUNCER_DEFAULT_POOL_SIZE=500
PGBOUNCER_RESERVE_POOL_SIZE=100

# App secrets (demo defaults, replace in production)
JWT_SECRET=change-me-in-prod

# Deploy behavior
RUN_MIGRATION=true
