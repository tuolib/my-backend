{
  "compilerOptions": {
    "target": "ESNext",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,
    "outDir": "./dist",
    "rootDir": ".",
    "baseUrl": ".",
    "paths": {
      "@database": ["packages/database"]
    },
    "types": ["bun"]
  },
  "include": ["apps/**/*", "services/**/*", "packages/**/*", "infra/**/*"],
  "exclude": ["node_modules", "dist"]
}
